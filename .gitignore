# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/

# ============================================
# 大型文件 - 绝对禁止提交 (> 10MB)
# ============================================

# 模型权重文件
checkpoints/*.pt
checkpoints/*.pth
checkpoints/*.onnx
checkpoints/*.tflite
checkpoints/*.npy
checkpoints/*.safetensors
models/**/*.pt
models/**/*.pth
models/**/*.onnx
models/**/*.onnx.data
models/**/*.safetensors
models/**/*.bin
models/**/*.ckpt
models/pretrained/
models/pretrained_finetuned/
models/quantized/*.pt
models/quantized/*.onnx
models/quantized/*.onnx.data
models/quantized/*.tflite

# 数据集 (原始数据 + 处理后的数据)
data/raw/
data/processed/*.json
data/processed/splits/
!data/processed/.gitkeep
*.zip
*.tar.gz
*.tgz
*.tar
*.wav
*.mp3
*.flac
*.ogg

# 日志和输出
logs/
runs/
*.log
tensorboard_logs/
outputs/
*.csv
*.json.bak

# ============================================
# Python 开发环境
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/

# ============================================
# OS / IDE
# ============================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# 保留目录结构 (空目录占位)
# ============================================
!data/splits/.gitkeep
!checkpoints/.gitkeep
!data/processed/.gitkeep
